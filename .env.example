# =============================================================================
# Discord Community TV Bot — environment variables
# =============================================================================
# Copy to `.env` and fill in real values. Never commit `.env`.
#
# See PLAN.md §12 and the blueprint for authoritative descriptions.
# -----------------------------------------------------------------------------

# ---- Discord (bot) ----
# Server / voice / text configuration is managed from the dashboard (/servers),
# NOT from env vars — no per-guild env config is required. Start the bot, then
# enable servers + pick channels in the dashboard and restart the bot.
#
# (Optional legacy bootstrap) To skip the dashboard for a quick single-server
# setup, you may uncomment + set these; the bot seeds them as one enabled server
# on first boot and the dashboard owns them afterwards. They are NOT required.
# DISCORD_GUILD_ID=
# DISCORD_VOICE_CHANNEL_ID=
# DISCORD_TEXT_CHANNEL_ID=
DISCORD_BOT_TOKEN=

# ---- Discord (dashboard OAuth2) ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/callback

# ---- Admin whitelist (comma-separated Discord user IDs) ----
ADMIN_USER_IDS=

# ---- File Provider ----
FILE_PROVIDER_BASE_URL=http://file-provider:8001

# ---- Playback / tracking ----
MIN_SESSION_SECONDS=30
CHECKPOINT_INTERVAL_SECONDS=3600

# ---- Dashboard ----
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# If set, allows logging in as "superadmin" with this password without needing Discord OAuth
SUPERADMIN_PASSWORD=

# ---- Database + cache paths (mounted volumes in Docker) ----
DATABASE_PATH=./data/tv.db
CACHE_PATH=./cache
CACHE_MAX_GB=10

# =============================================================================
# File provider service (separate service, same repo under file_provider/)
# =============================================================================

# Provider order: comma-separated, tried in sequence per §4.1 fallback.
# Available: local, torrent, archive, telegram. Torrent files enabled in the
# dashboard are included in the playlist after the next provider scan.
FILE_PROVIDER_ORDER=local,torrent

# ---- Torrent client (aria2) -----------------------------------------------
# The file-provider image installs aria2 and starts it on loopback. The
# dashboard talks to the provider API; do not expose this RPC port publicly.
FILE_PROVIDER_TORRENT_ENABLED=1
FILE_PROVIDER_TORRENT_RPC_URL=http://127.0.0.1:6800/jsonrpc
FILE_PROVIDER_TORRENT_RPC_SECRET=
FILE_PROVIDER_TORRENT_RPC_PORT=6800
# Remote RPC is rejected by default; only enable this when the RPC endpoint
# is separately secured and intentionally managed outside this container.
FILE_PROVIDER_TORRENT_ALLOW_REMOTE_RPC=0
FILE_PROVIDER_TORRENT_DATA_PATH=/data/torrents
FILE_PROVIDER_TORRENT_BINARY=aria2c
# Safety limits: 0 GB disables the aggregate torrent-size guard.
FILE_PROVIDER_TORRENT_MAX_SIZE_GB=10
FILE_PROVIDER_TORRENT_MAX_UPLOAD_MB=16
# Comma-separated extensions allowed in the radio playlist. Empty means none.
FILE_PROVIDER_TORRENT_ALLOWED_EXTENSIONS=.mp3,.m4a,.m4b,.opus,.ogg,.oga,.flac,.wav,.aac,.aif,.aiff,.wma,.mka,.ac3,.eac3,.dts,.amr,.ape,.alac,.caf,.dsf,.dff,.wv,.tta,.tak,.mid,.midi,.mp4,.m4v,.mov,.mkv,.webm,.avi,.wmv,.flv,.mpg,.mpeg,.ts,.3gp,.m2ts,.mts,.m2v,.vob,.ogv,.ogm,.asf,.rm,.rmvb,.3g2,.divx,.mxf

# ---- File provider database & cache ----
FILE_PROVIDER_DB_PATH=./data/provider.db
FILE_PROVIDER_CACHE_PATH=./cache
FILE_PROVIDER_CACHE_MAX_GB=10
FILE_PROVIDER_HOST=0.0.0.0
FILE_PROVIDER_PORT=8001

# ---- Local provider (dev/testing) ----
# Directory scanned recursively for playable files:
#   audio: mp3, m4a, m4b, opus, ogg, oga, flac, wav, aac, aif, aiff, wma
#   video: mp4, m4v, mov, mkv, webm, avi, wmv, flv, mpg, mpeg, ts, 3gp
# Video containers are accepted too — FFmpeg strips the video track and
# streams just the audio (Discord voice channels are audio-only).
LOCAL_MEDIA_PATH=./media

# ---- archive.org (Internet Archive) provider ----
# Comma-separated Internet Archive item ids. Each item's "source: original"
# audio files (mp3/m4a/ogg/flac/wav/...) become playlist entries.
# Public API, no auth. Example (Dr. Hawkins lectures):
#   ARCHIVE_ORG_ITEMS=Hawkins_Lectures_transcoded_actual_files
# Multiple items:
#   ARCHIVE_ORG_ITEMS=item_one,item_two,item_three
ARCHIVE_ORG_ITEMS=

# ---- Telegram / Telethon (MTProto) ----
# Get api_id and api_hash from https://my.telegram.org/apps
# Channel id: numeric, use -100XXXXXXXXXX for channels/supergroups
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHANNEL_ID=
# Session string is stored on disk at FILE_PROVIDER_DB_PATH's parent as
# `telethon.session.txt`. First run will prompt interactively for phone + code.
